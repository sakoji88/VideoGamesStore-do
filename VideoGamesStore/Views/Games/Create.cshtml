@model VideoGamesStore.Models.Game
@{ ViewData["Title"] = "Добавить игру"; }
<h2 class="mb-4">Добавить игру</h2>
<form asp-action="Create" method="post">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="mb-3">
        <label asp-for="Title" class="form-label"></label>
        <input asp-for="Title" class="form-control" />
        <div class="form-text">Пример: Cyberpunk 2077</div>
        <span asp-validation-for="Title" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Description" class="form-label"></label>
        <textarea asp-for="Description" class="form-control" rows="4"></textarea>
        <div class="form-text">Пример: Ролевая игра в открытом мире Night City, с сюжетом и побочными заданиями.</div>
        <span asp-validation-for="Description" class="text-danger"></span>
    </div>

    <div class="row">
        <div class="col-md-4 mb-3">
            <label asp-for="Price" class="form-label"></label>
            <input asp-for="Price" class="form-control" type="number" min="0.01" step="0.01" />
            <div class="form-text">Пример: 1999.99</div>
            <span asp-validation-for="Price" class="text-danger"></span>
        </div>
        <div class="col-md-4 mb-3">
            <label asp-for="Stock" class="form-label"></label>
            <input asp-for="Stock" class="form-control" type="number" min="0" />
            <div class="form-text">Пример: 35</div>
            <span asp-validation-for="Stock" class="text-danger"></span>
        </div>
        <div class="col-md-4 mb-3">
            <label asp-for="Rating" class="form-label"></label>
            <input asp-for="Rating" class="form-control" type="number" min="0" max="10" step="0.1" />
            <div class="form-text">Пример: 8.7</div>
            <span asp-validation-for="Rating" class="text-danger"></span>
        </div>
    </div>

    <div class="mb-3">
        <label class="form-label">Жанр</label>
        <select asp-for="GenreId" asp-items="ViewBag.Genres" class="form-select"></select>
        <div class="input-group mt-2">
            <input name="genreName" form="addGenreForm" class="form-control" placeholder="Новый жанр" />
            <button form="addGenreForm" class="btn btn-outline-secondary" type="submit">Добавить жанр</button>
        </div>
    </div>
    <div class="mb-3">
        <label class="form-label">Издатель</label>
        <select asp-for="PublisherId" asp-items="ViewBag.Publishers" class="form-select"><option value="">Не указан</option></select>
        <div class="input-group mt-2">
            <input name="publisherName" form="addPublisherForm" class="form-control" placeholder="Новый издатель" />
            <button form="addPublisherForm" class="btn btn-outline-secondary" type="submit">Добавить издателя</button>
        </div>
    </div>
    <div class="mb-3">
        <label class="form-label">Платформы</label>
        <select name="selectedPlatforms" asp-items="ViewBag.Platforms" multiple class="form-select"></select>
        <div class="input-group mt-2">
            <input name="platformName" form="addPlatformForm" class="form-control" placeholder="Новая платформа" />
            <button form="addPlatformForm" class="btn btn-outline-secondary" type="submit">Добавить платформу</button>
        </div>
    </div>

    <div class="mb-3">
        <label asp-for="CoverImageUrl" class="form-label"></label>
        <input asp-for="CoverImageUrl" class="form-control" />
        <div class="form-text">Пример: /images/games/cyberpunk.jpg или https://site.com/cyberpunk.jpg</div>
        <span asp-validation-for="CoverImageUrl" class="text-danger"></span>
    </div>
    <div class="mb-3"><label asp-for="ReleaseDate" class="form-label"></label><input asp-for="ReleaseDate" type="date" class="form-control" /></div>
    <div class="mb-3">
        <label asp-for="AgeRating" class="form-label"></label>
        <input asp-for="AgeRating" class="form-control" />
        <div class="form-text">Пример: 18+</div>
        <span asp-validation-for="AgeRating" class="text-danger"></span>
    </div>
    <div class="form-check mb-3"><input asp-for="IsActive" class="form-check-input" /><label asp-for="IsActive" class="form-check-label"></label></div>
    <button type="submit" class="btn btn-primary">Создать</button>
</form>

<form id="addGenreForm" asp-action="AddGenre" method="post">@Html.AntiForgeryToken()<input type="hidden" name="returnAction" value="Create" /></form>
<form id="addPublisherForm" asp-action="AddPublisher" method="post">@Html.AntiForgeryToken()<input type="hidden" name="returnAction" value="Create" /></form>
<form id="addPlatformForm" asp-action="AddPlatform" method="post">@Html.AntiForgeryToken()<input type="hidden" name="returnAction" value="Create" /></form>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
